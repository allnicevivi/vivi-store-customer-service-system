# ============================================================
# 快速開始 Quick Start
# 1. cp .env.example .env
# 2. 填入 GEMINI_API_KEY（唯一必填項）
# 3. 其餘預設值可直接搭配 Docker Compose 使用
# ============================================================

# ── Gemini AI（必填）────────────────────────────────────────
# 取得 API Key：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash          # 文字生成模型
GEMINI_EMBED_MODEL=gemini-embedding-001 # 向量嵌入模型（語意搜尋 / 快取）

# ── Kafka（訊息佇列）────────────────────────────────────────
# Docker 容器內：kafka:9092　｜　本機直接跑：localhost:9094
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# ── ChromaDB（向量資料庫）───────────────────────────────────
# Docker 容器內：chromadb　　｜　本機直接跑：localhost
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Redis（語意快取）────────────────────────────────────────
# Docker 容器內：redis　　　 ｜　本機直接跑：localhost
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MongoDB（審計日誌 / 成本追蹤）──────────────────────────
# Docker 容器內：mongodb:27017 ｜ 本機直接跑：localhost:27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pcalife

# ── 知識庫路徑 ──────────────────────────────────────────────
# Docker 容器內預設 /app/knowledge_base/
# 本機直接跑時請改為絕對路徑，例如：
#   FAQ_FILE=/path/to/PcaHW/knowledge_base/ecommerce_faq.md
FAQ_FILE=./knowledge_base/ecommerce_faq.md
POLICY_FILE=./knowledge_base/ecommerce_policy.md

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
QUIET_THIRD_PARTY_LOGS=1 # 設 0 可顯示 kafka / httpx 等依賴套件的詳細 log
